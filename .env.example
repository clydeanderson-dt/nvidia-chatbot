# =============================================================================
# nvidia-chatbot — unified environment file
# =============================================================================
#
# Single source of truth for the backend, the load generator, and the frontend
# build. Copy this file to `.env` (in the repo root) and fill in the values.
#
#   cp .env.example .env
#
# Used by:
#   - Local dev:  `backend/main.py`, `backend/services/llm.py`, and
#                 `load_gen/load_gen.py` load this file via `load_dotenv()`
#                 regardless of the CWD they are launched from.
#   - VM deploy:  `deploy/setup.sh` validates this file and copies it to
#                 `/opt/chatbot/.env`, which both systemd units read via
#                 `EnvironmentFile=`.
#   - Frontend:   `deploy/setup.sh` exports `VITE_DYNATRACE_RUM_URL` before
#                 running `npm run build`, so Vite picks it up automatically.
#
# Notes:
#   - Do not quote values unless the value itself contains spaces or `#`.
#     systemd's EnvironmentFile parser treats quotes literally in some
#     versions, and python-dotenv strips them. Keeping them unquoted avoids
#     subtle diffs between local dev and the VM.
#   - No trailing slashes on URLs.
#   - This file is gitignored. Never commit it.
#
# =============================================================================


# -----------------------------------------------------------------------------
# MANDATORY
# -----------------------------------------------------------------------------

# Your NVIDIA NIM API key from https://build.nvidia.com (starts with `nvapi-`).
# The backend will refuse to serve `/api/chat` without it.
# Example: NVIDIA_API_KEY=nvapi-abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
NVIDIA_API_KEY=


# -----------------------------------------------------------------------------
# OPTIONAL — Chaos engineering (DevCycle feature flags)
# -----------------------------------------------------------------------------

# Server SDK key for the `nvidia-chatbot` DevCycle project.
# Get it from: DevCycle dashboard → Settings → SDK Keys → Production → Server.
#
# If unset:
#   - The backend logs a warning at startup and skips DevCycle init.
#   - `services/chaos.py` falls back to default values (all chaos disabled),
#     so the app behaves as if the `healthy` preset is always served.
#   - The GitHub Actions chaos workflow can still PATCH DevCycle, but the
#     deployed backend will never see the change.
#
# Set this to enable runtime chaos injection driven by DevCycle.
# Example: DEVCYCLE_SERVER_SDK_KEY=dvc_server_abcdef0123456789abcdef0123456789abcdef0123456789_hash
DEVCYCLE_SERVER_SDK_KEY=


# -----------------------------------------------------------------------------
# OPTIONAL — OpenTelemetry export (shared by backend and load_gen)
# -----------------------------------------------------------------------------

# OTel collector HTTP/protobuf endpoint (port 4318 by default).
# If unset, tracing and log export are skipped with a warning — the services
# still start and serve traffic normally.
# Example: OTLP_ENDPOINT=http://localhost:4318
OTLP_ENDPOINT=


# -----------------------------------------------------------------------------
# OPTIONAL — Backend
# -----------------------------------------------------------------------------

# Comma-separated list of allowed frontend origins for CORS.
# Include the protocol; no trailing slashes.
#
# On the VM, `deploy/setup.sh` augments this with `http://<vm-ip>` and
# `http://<vm-hostname>` automatically — you only need to add additional
# origins here (e.g. a custom domain). Localhost dev origins
# (http://localhost:5173, http://localhost:3000) are also added by default.
# Example: ALLOWED_ORIGINS=https://chatbot.example.com,https://staging.example.com
ALLOWED_ORIGINS=

# Base URL of a self-hosted NIM instance (no trailing slash, no `/v1`).
# If set, users can select "Self-Hosted NIM" as a provider in the UI.
# Example: SELF_HOSTED_NIM_URL=http://nim.internal:8000
SELF_HOSTED_NIM_URL=


# -----------------------------------------------------------------------------
# OPTIONAL — Frontend build (Dynatrace Real User Monitoring)
# -----------------------------------------------------------------------------

# Dynatrace RUM JavaScript tag URL — injected into the React build by Vite.
# Get it from:
#   Dynatrace → Web Applications → Your App → ⋯ → Edit → Setup → Code snippet
#
# Leave unset to disable browser RUM. If you change this after the initial
# deploy, re-run `deploy/setup.sh` (or rebuild the frontend manually) to pick
# up the new value.
# Example: VITE_DYNATRACE_RUM_URL=https://js-cdn.dynatracelabs.com/jstag/abc123/456def/complete.js
VITE_DYNATRACE_RUM_URL=


# -----------------------------------------------------------------------------
# OPTIONAL — Load generator
# -----------------------------------------------------------------------------

# Backend base URL the load generator hits. On the VM this should usually
# stay as localhost since the load generator runs alongside the backend.
# Default (when unset): http://localhost:8000
# Example: LOAD_GEN_URL=http://localhost:8000
LOAD_GEN_URL=

# Number of concurrent async workers.
# Default (when unset): 10
# Example: LOAD_GEN_CONCURRENCY=10
LOAD_GEN_CONCURRENCY=

# LLM provider sent in each request payload: `nim_api` or `self_hosted`.
# Default (when unset): nim_api
# Example: LOAD_GEN_PROVIDER=nim_api
LOAD_GEN_PROVIDER=

# Target requests per second. Leave unset for constant-concurrency mode.
# Example: LOAD_GEN_RATE=5
LOAD_GEN_RATE=


# -----------------------------------------------------------------------------
# OPTIONAL — nginx (VM deploy only)
# -----------------------------------------------------------------------------

# Hostname or IP that nginx serves the chatbot under (no protocol).
# If unset, `deploy/setup.sh` defaults to the VM's primary IP from
# `hostname -I`.
# Example: SERVER_NAME=chatbot.example.com
SERVER_NAME=
