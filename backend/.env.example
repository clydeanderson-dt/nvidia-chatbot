# Copy this file to .env and fill in the values.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of allowed frontend origins (no trailing slash).
# On the VM, set this to your VM's IP or domain. Example:
#   ALLOWED_ORIGINS=http://192.168.1.10,https://mychatbot.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: self-hosted NIM base URL (no trailing slash, no /v1 path).
# If set, users can select "Self-Hosted NIM" in the UI.
SELF_HOSTED_NIM_URL=

# Dynatrace OpenTelemetry export.
# Both values are required — the server will not start without them.
# Token needs scopes: openTelemetryTrace.ingest, metrics.ingest, logs.ingest
DYNATRACE_OTLP_ENDPOINT=https://{environmentId}.live.dynatrace.com
DYNATRACE_API_TOKEN=dt0a01.xxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
