# Copy this file to .env and fill in the values.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEVCYCLE_SERVER_SDK_KEY=dvc_server_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of allowed frontend origins (no trailing slash).
# On the VM, set this to your VM's IP or domain. Example:
#   ALLOWED_ORIGINS=http://192.168.1.10,https://mychatbot.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: self-hosted NIM base URL (no trailing slash, no /v1 path).
# If set, users can select "Self-Hosted NIM" in the UI.
SELF_HOSTED_NIM_URL=

# OpenTelemetry export (optional).
# Point to your OTel collector's HTTP/protobuf endpoint (port 4318 by default).
# If unset, tracing and log export are skipped with a warning.
OTLP_ENDPOINT=http://localhost:4318
