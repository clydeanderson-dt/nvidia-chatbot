        "query": "fetch spans\n| filter dt.service.name == \"nvidia-chatbot\"\n| filter span.name == \"ChatNVIDIA.chat\"\n| filter isNotNull(gen_ai.usage.input_tokens)\n| fieldsAdd join_key = span.parent_id\n| join [\n    fetch spans\n    | filter dt.service.name == \"nvidia-chatbot\"\n    | filter in(span.name, {\"chat_suggestions.task\",\"chat_starter_suggestions.task\"})\n    | fieldsAdd join_key = span.id\n  ], on:{join_key}, kind:leftOuter\n| filter isNotNull(right.span.name) != true\n| filter toLong(duration) \u003e 0\n| fieldsAdd record_cost = (toDouble(gen_ai.usage.input_tokens) / 1000000.0) * $PriceIn:noquote + (toDouble(gen_ai.usage.output_tokens) / 1000000.0) * $PriceOut:noquote\n| summarize {avg_duration_ms = toDouble(avg(duration) / 1000000.0), avg_cost_per_call_usd = avg(record_cost), calls = count()}, by:{model = gen_ai.request.model}\n| fieldsKeep model, avg_duration_ms, avg_cost_per_call_usd, calls\n| sort calls desc",
