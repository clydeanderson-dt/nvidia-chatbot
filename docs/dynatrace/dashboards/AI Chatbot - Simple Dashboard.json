      "28": {
        "davis": {
          "davisVisualization": {
            "isAvailable": true
          }
        },
        "query": "fetch spans\n| filter dt.service.name == \"nvidia-chatbot\"\n| filter span.name == \"ChatNVIDIA.chat\"\n| filter isNotNull(gen_ai.usage.input_tokens)\n| fieldsAdd join_key = span.parent_id\n| join [\n    fetch spans\n    | filter dt.service.name == \"nvidia-chatbot\"\n    | filter in(span.name, {\"chat_suggestions.task\",\"chat_starter_suggestions.task\"})\n    | fieldsAdd join_key = span.id\n  ], on:{join_key}, kind:leftOuter\n| filter isNotNull(right.span.name) != true\n| summarize {in_tok = sum(gen_ai.usage.input_tokens), out_tok = sum(gen_ai.usage.output_tokens)}\n| fieldsAdd cost_usd = (toDouble(in_tok) / 1000000.0) * $PriceIn:noquote + (toDouble(out_tok) / 1000000.0) * $PriceOut:noquote\n| fields cost_usd",
        "querySettings": {
          "defaultSamplingRatio": 10,
          "defaultScanLimitGbytes": 500,
          "enableSampling": false,
          "maxResultMegaBytes": 1,
          "maxResultRecords": 1000
        },
        "title": "Chat est cost (USD)",
        "type": "data",
        "visualization": "singleValue",
        "visualizationSettings": {
          "singleValue": {
            "label": "USD",
            "prefixIcon": "currencydollar"
          }
        }
      },
