# Copy this file to .env and fill in the values.

# URL of the running backend (no trailing slash).
LOAD_GEN_URL=http://localhost:8000

# Number of concurrent async workers.
LOAD_GEN_CONCURRENCY=5

# Target requests per second (omit or leave blank to use constant-concurrency mode).
# LOAD_GEN_RATE=

# LLM provider sent in each request payload: nim_api | self_hosted
LOAD_GEN_PROVIDER=nim_api

# Dynatrace OpenTelemetry export (optional — telemetry is skipped if either is absent).
# Token needs scope: openTelemetryTrace.ingest
DYNATRACE_OTLP_ENDPOINT=https://{environmentId}.live.dynatrace.com
DYNATRACE_API_TOKEN=dt0a01.xxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
